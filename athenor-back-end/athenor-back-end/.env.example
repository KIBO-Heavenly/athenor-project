# ============================================
# Athenor API Environment Variables
# ============================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control!

# JWT Settings - Generate a strong random secret
JWT_SECRET=your-super-secret-jwt-key-change-this-minimum-32-characters-long
JWT_ISSUER=AthenorAPI
JWT_AUDIENCE=AthenorClient
JWT_EXPIRY_MINUTES=60

# Database Connection (if using SQL Server instead of SQLite)
# CONNECTION_STRING=Server=...;Database=...;User=...;Password=...

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Athenor

# Frontend URL for CORS and email links
FRONTEND_URL=https://your-frontend-url.azurestaticapps.net

# Azure Key Vault (Optional - for production)
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
